<Window x:Class="WpfTargAuto.AdaugaMasinaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adauga Masina"
        Height="680" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="ADAUGA MASINA NOUA"
                       FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                       Foreground="#E94560" Margin="0,0,0,20"/>

            <!-- Firma -->
            <Label x:Name="lblFirma" Content="Firma producatoare"
                   Foreground="#AAAAAA" FontFamily="Consolas" FontSize="13"
                   Padding="0" Margin="0,0,0,4"/>
            <TextBox x:Name="txtFirma"
                     Height="36" FontFamily="Consolas" FontSize="13"
                     Background="#2A2A3E" Foreground="White"
                     BorderBrush="#444466" Padding="8,0"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="errFirma" Text="Firma trebuie sa aiba intre 2 si 30 de caractere!"
                       Foreground="Red" FontFamily="Consolas" FontSize="11"
                       Margin="0,3,0,0" Visibility="Collapsed"/>

            <!-- Model -->
            <Label x:Name="lblModel" Content="Model"
                   Foreground="#AAAAAA" FontFamily="Consolas" FontSize="13"
                   Padding="0" Margin="0,12,0,4"/>
            <TextBox x:Name="txtModel"
                     Height="36" FontFamily="Consolas" FontSize="13"
                     Background="#2A2A3E" Foreground="White"
                     BorderBrush="#444466" Padding="8,0"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="errModel" Text="Modelul trebuie sa aiba intre 1 si 30 de caractere!"
                       Foreground="Red" FontFamily="Consolas" FontSize="11"
                       Margin="0,3,0,0" Visibility="Collapsed"/>

            <!-- An fabricatie -->
            <Label x:Name="lblAn" Content="An fabricatie"
                   Foreground="#AAAAAA" FontFamily="Consolas" FontSize="13"
                   Padding="0" Margin="0,12,0,4"/>
            <TextBox x:Name="txtAn"
                     Height="36" FontFamily="Consolas" FontSize="13"
                     Background="#2A2A3E" Foreground="White"
                     BorderBrush="#444466" Padding="8,0"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="errAn"
                       Foreground="Red" FontFamily="Consolas" FontSize="11"
                       Margin="0,3,0,0" Visibility="Collapsed"/>

            <!-- Serie VIN -->
            <Label x:Name="lblVin" Content="Serie sasiu (VIN)"
                   Foreground="#AAAAAA" FontFamily="Consolas" FontSize="13"
                   Padding="0" Margin="0,12,0,4"/>
            <TextBox x:Name="txtVin"
                     Height="36" FontFamily="Consolas" FontSize="13"
                     Background="#2A2A3E" Foreground="White"
                     BorderBrush="#444466" Padding="8,0"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="errVin" Text="VIN-ul trebuie sa aiba intre 5 si 20 de caractere!"
                       Foreground="Red" FontFamily="Consolas" FontSize="11"
                       Margin="0,3,0,0" Visibility="Collapsed"/>

            <!-- Culoare -->
            <Label x:Name="lblCuloare" Content="Culoare"
                   Foreground="#AAAAAA" FontFamily="Consolas" FontSize="13"
                   Padding="0" Margin="0,12,0,8"/>

            <!-- Butoane culoare -->
            <WrapPanel x:Name="pnlCulori" Margin="0,0,0,4"/>

            <TextBlock x:Name="errCuloare" Text="Selectati o culoare!"
                       Foreground="Red" FontFamily="Consolas" FontSize="11"
                       Margin="0,3,0,0" Visibility="Collapsed"/>

            <!-- Preview culoare selectata -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Selectata: "
                           Foreground="#AAAAAA" FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center"/>
                <Border x:Name="rectPreviewCuloare"
                        Width="24" Height="24" CornerRadius="4"
                        Background="#2A2A3E" BorderBrush="#444466"
                        BorderThickness="1" Margin="6,0,8,0"/>
                <TextBlock x:Name="txtCuloareSelectata"
                           Text="Niciuna"
                           Foreground="#AAAAAA" FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Optiuni -->
            <Label Content="Optiuni disponibile"
                   Foreground="#AAAAAA" FontFamily="Consolas" FontSize="13"
                   Padding="0" Margin="0,16,0,8"/>

            <WrapPanel x:Name="pnlOptiuni"/>

            <!-- Butoane -->
            <Grid Margin="0,24,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Salveaza"
                        Height="38" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                        Background="#E94560" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="btnSalveaza_Click"/>

                <Button Grid.Column="2" Content="Anuleaza"
                        Height="38" FontFamily="Consolas" FontSize="13"
                        Background="#2A2A3E" Foreground="#AAAAAA" BorderThickness="0"
                        Cursor="Hand" Click="btnAnuleaza_Click"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Window>