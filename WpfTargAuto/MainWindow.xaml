<Window x:Class="WpfTargAuto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="Gestiune Targ Auto"
        Height="600" Width="950"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent"   Color="#E94560"/>
        <SolidColorBrush x:Key="CardFund" Color="#2A2A3E"/>
        <SolidColorBrush x:Key="TextAlb"  Color="#EAEAEA"/>
        <SolidColorBrush x:Key="TextGri"  Color="#888899"/>
        <SolidColorBrush x:Key="Verde"    Color="#2ECC71"/>
        <SolidColorBrush x:Key="Galben"   Color="#F39C12"/>

        <Style TargetType="DatePicker">
            <Setter Property="Background"   Value="#2A2A3E"/>
            <Setter Property="Foreground"   Value="#EAEAEA"/>
            <Setter Property="BorderBrush"  Value="#444466"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="13"/>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background"   Value="#2A2A3E"/>
            <Setter Property="Foreground"   Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"   Value="#2A2A3E"/>
            <Setter Property="Foreground"   Value="#EAEAEA"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="8,6"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground"        Value="#EAEAEA"/>
            <Setter Property="FontFamily"        Value="Consolas"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Padding"           Value="10,8"/>
            <Setter Property="Margin"            Value="0,0,0,4"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E94560"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22223A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StilBtnMeniu" TargetType="RadioButton">
            <Setter Property="Foreground"                 Value="#888899"/>
            <Setter Property="FontFamily"                 Value="Consolas"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Padding"                    Value="12,10"/>
            <Setter Property="Margin"                     Value="0,0,0,4"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#EAEAEA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22223A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StilBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0354F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StilBtnSecundar" TargetType="Button" BasedOn="{StaticResource StilBtn}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
        </Style>

        <Style x:Key="StilTextBox" TargetType="TextBox">
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontFamily"               Value="Consolas"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Background"               Value="#2A2A3E"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#444466"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StilComboBox" TargetType="ComboBox">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#EAEAEA"/>
            <Setter Property="Background"      Value="#2A2A3E"/>
            <Setter Property="BorderBrush"     Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.ColumnSpan="2"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"/>

                            <ContentPresenter Grid.Column="0"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center"
                                      TextBlock.Foreground="#EAEAEA"
                                      TextBlock.FontFamily="Consolas"
                                      TextBlock.FontSize="13"/>

                            <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  IsChecked="{Binding IsDropDownOpen,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Mode=TwoWay}"
                                  Focusable="False"/>

                            <TextBlock Grid.Column="1" Text="▾"
                               Foreground="#EAEAEA"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>

                            <Popup x:Name="PART_Popup"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False">
                                <Border Background="#2A2A3E"
                                BorderBrush="#444466"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StilLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- MENIU STANGA -->
        <Border Grid.Column="0" Background="#12122A">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="TARG AUTO"
                               FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="Gestiune vehicule"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextGri}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="10,0,10,0">
                    <RadioButton x:Name="btnMeniuLista"   Content="Lista masini"
                                 Style="{StaticResource StilBtnMeniu}"
                                 IsChecked="True" Checked="BtnMeniu_Checked"/>
                    <RadioButton x:Name="btnMeniuCautare" Content="Cauta masina"
                                 Style="{StaticResource StilBtnMeniu}"
                                 Checked="BtnMeniu_Checked"/>
                    <RadioButton x:Name="btnMeniuAdauga"  Content="Adauga masina"
                                 Style="{StaticResource StilBtnMeniu}"
                                 Checked="BtnMeniu_Checked"/>
                    <RadioButton x:Name="btnMeniuEditeaza" Content="Editeaza masina"
                                 Style="{StaticResource StilBtnMeniu}"
                                 Checked="BtnMeniu_Checked"/>
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Padding="16,12">
                    <TextBlock x:Name="txtStatus"
                               Text="0 masini"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextGri}"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- CONTINUT DREAPTA -->
        <Grid Grid.Column="1">

            <!-- PAGINA 1: Lista masini -->
            <Grid x:Name="paginaLista" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2A2A3E" Padding="24,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Lista masini disponibile"
                                       FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextAlb}"/>
                            <TextBlock x:Name="txtSubtitluLista"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource TextGri}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Content="- Sterge"
                                Style="{StaticResource StilBtnSecundar}"
                                VerticalAlignment="Center"
                                Click="btnSterge_Click" Margin="8,0,0,0"/>

                        <Button DockPanel.Dock="Right"
                                Content="+ Adauga"
                                Style="{StaticResource StilBtn}"
                                Click="btnAdauga_Click" Width="212"/>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1" Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="150"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1.5*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- ListBox masini -->
                    <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="8">
                        <ListBox x:Name="lstMasini"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#EAEAEA"
                                 FontFamily="Consolas" FontSize="12"
                                 Padding="8"
                                 SelectionChanged="lstMasini_SelectionChanged"/>
                    </Border>

                    <!-- Detalii masina selectata -->
                    <Border Grid.Column="2" Background="#2A2A3E"
                            CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock x:Name="txtPlaceholder"
                                       Text="Selectati o masina din lista"
                                       FontFamily="Consolas" FontSize="14"
                                       Foreground="{StaticResource TextGri}"
                                       HorizontalAlignment="Center"
                                       Margin="0,60,0,0"/>

                            <StackPanel x:Name="pnlDetalii" Visibility="Collapsed">
                                <TextBlock x:Name="txtDetaliuTitlu"
                                           FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextAlb}"
                                           Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                        <TextBlock Text="Firma" Style="{StaticResource StilLabel}"/>
                                        <TextBlock x:Name="txtFirma" FontFamily="Consolas"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{StaticResource TextAlb}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                        <TextBlock Text="Model" Style="{StaticResource StilLabel}"/>
                                        <TextBlock x:Name="txtModel" FontFamily="Consolas"
                                                   FontSize="13" Foreground="{StaticResource TextAlb}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                        <TextBlock Text="An fabricatie" Style="{StaticResource StilLabel}"/>
                                        <TextBlock x:Name="txtAn" FontFamily="Consolas"
                                                   FontSize="13" Foreground="{StaticResource Galben}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                                        <TextBlock Text="Serie VIN" Style="{StaticResource StilLabel}"/>
                                        <TextBlock x:Name="txtVin" FontFamily="Consolas"
                                                   FontSize="11" Foreground="{StaticResource TextGri}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                                        <TextBlock Text="Data adaugarii" Style="{StaticResource StilLabel}"/>
                                        <TextBlock x:Name="txtData" FontFamily="Consolas"
                                                   FontSize="13" Foreground="{StaticResource TextAlb}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Culoare" Style="{StaticResource StilLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border x:Name="rectCuloare" Width="22" Height="22"
                                            CornerRadius="4" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="txtCuloare" FontFamily="Consolas"
                                               FontSize="13" Foreground="{StaticResource TextAlb}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="Optiuni" Style="{StaticResource StilLabel}"/>
                                <TextBlock x:Name="txtOptiuni" FontFamily="Consolas"
                                           FontSize="12" Foreground="{StaticResource Verde}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- PAGINA 2: Cautare -->
            <Grid x:Name="paginaCautare" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2A2A3E" Padding="24,16">
                    <TextBlock Text="Cauta masina"
                               FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextAlb}"/>
                </Border>

                <StackPanel Grid.Row="1" Margin="24,20,24,0"
                            MaxWidth="500" HorizontalAlignment="Left">

                    <TextBlock Text="Cauta dupa:"
                               FontFamily="Consolas" FontSize="13"
                               Foreground="{StaticResource TextGri}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton x:Name="rbFirma" Content="Firma" IsChecked="True"
                                     Foreground="{StaticResource TextAlb}"
                                     FontFamily="Consolas" FontSize="13" Margin="0,0,20,0"/>
                        <RadioButton x:Name="rbAn" Content="An fabricatie"
                                     Foreground="{StaticResource TextAlb}"
                                     FontFamily="Consolas" FontSize="13" Margin="0,0,20,0"/>
                        <RadioButton x:Name="rbVin" Content="Serie VIN"
                                     Foreground="{StaticResource TextAlb}"
                                     FontFamily="Consolas" FontSize="13"/>
                    </StackPanel>

                    <TextBlock Text="Termen de cautare" Style="{StaticResource StilLabel}"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txtCautare"
                                 Style="{StaticResource StilTextBox}"/>
                        <Button Grid.Column="2" Content="Cauta"
                                Style="{StaticResource StilBtn}"
                                Click="btnCauta_Click"/>
                    </Grid>

                    <TextBlock x:Name="txtRezCautare" FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource TextGri}" Margin="0,0,0,8"/>

                    <!-- ListBox pentru rezultate cautare -->
                    <Border Background="#2A2A3E" CornerRadius="8" MaxHeight="300">
                        <ListBox x:Name="lstRezultate"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextAlb}"
                                 FontFamily="Consolas" FontSize="12"
                                 Padding="8"
                                 SelectionMode="Single"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- PAGINA 3: Adauga masina -->
            <Grid x:Name="paginaAdauga" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2A2A3E" Padding="24,16">
                    <TextBlock Text="Adauga masina noua"
                               FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextAlb}"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20,24,20" MaxWidth="500" HorizontalAlignment="Left">

                        <!-- Firma -->
                        <TextBlock Text="Firma producatoare" Style="{StaticResource StilLabel}"/>
                        <TextBox x:Name="txtAddFirma" Style="{StaticResource StilTextBox}"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="errAddFirma"
                                   Text="Firma trebuie sa aiba intre 2 si 30 de caractere!"
                                   Foreground="Red" FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,8" Visibility="Collapsed"/>

                        <!-- Model -->
                        <TextBlock Text="Model" Style="{StaticResource StilLabel}" Margin="0,8,0,4"/>
                        <TextBox x:Name="txtAddModel" Style="{StaticResource StilTextBox}"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="errAddModel"
                                   Text="Modelul trebuie sa aiba intre 1 si 30 de caractere!"
                                   Foreground="Red" FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,8" Visibility="Collapsed"/>

                        <!-- An + VIN -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="An fabricatie" Style="{StaticResource StilLabel}"/>
                                <TextBox x:Name="txtAddAn" Style="{StaticResource StilTextBox}"
                                         Margin="0,0,0,4"/>
                                <TextBlock x:Name="errAddAn" Foreground="Red"
                                           FontFamily="Consolas" FontSize="11"
                                           Margin="0,0,0,8" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Serie sasiu (VIN)" Style="{StaticResource StilLabel}"/>
                                <TextBox x:Name="txtAddVin" Style="{StaticResource StilTextBox}"
                                         Margin="0,0,0,4"/>
                                <TextBlock x:Name="errAddVin"
                                           Text="VIN-ul trebuie sa aiba intre 5 si 20 de caractere!"
                                           Foreground="Red" FontFamily="Consolas" FontSize="11"
                                           Margin="0,0,0,8" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>

                        <!-- Data adaugarii - DatePicker -->
                        <TextBlock Text="Data adaugarii" Style="{StaticResource StilLabel}"
                                   Margin="0,8,0,4"/>
                        <DatePicker x:Name="dtpAddData"
                                    Height="34" FontFamily="Consolas" FontSize="13"
                                    Background="#2A2A3E" Foreground="White"
                                    BorderBrush="#444466"
                                    SelectedDateFormat="Short"
                                    DisplayDateEnd="{x:Static system:DateTime.Today}"
                                    Margin="0,0,0,12"/>

                        <!-- Culoare - ComboBox -->
                        <TextBlock Text="Culoare" Style="{StaticResource StilLabel}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbAddCuloare"
                                  Style="{StaticResource StilComboBox}"
                                  Margin="0,0,0,4"
                                  SelectionChanged="cmbAddCuloare_SelectionChanged"/>
                        <TextBlock x:Name="errAddCuloare" Text="Selectati o culoare!"
                                   Foreground="Red" FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,8" Visibility="Collapsed"/>

                        <!-- Preview culoare -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border x:Name="rectAddPreview" Width="20" Height="20"
                                    CornerRadius="4" Background="#2A2A3E"
                                    BorderBrush="#444466" BorderThickness="1" Margin="0,0,8,0"/>
                            <TextBlock x:Name="txtAddCuloareSelectata" Text="Niciuna"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource TextGri}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Optiuni cu CheckBox -->
                        <TextBlock Text="Optiuni disponibile" Style="{StaticResource StilLabel}"
                                   Margin="0,0,0,8"/>
                        <WrapPanel x:Name="pnlAddOptiuni" Margin="0,0,0,16"/>

                        <!-- Butoane -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Salveaza"
                                    Style="{StaticResource StilBtn}"
                                    Height="38" FontWeight="Bold"
                                    Click="btnSalveazaInline_Click"/>
                            <Button Grid.Column="2" Content="Anuleaza"
                                    Style="{StaticResource StilBtnSecundar}"
                                    Height="38" Click="btnAnuleazaInline_Click"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- PAGINA 4: Editeaza masina -->
            <Grid x:Name="paginaEditeaza" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2A2A3E" Padding="24,16">
                    <TextBlock Text="Editeaza masina"
                   FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextAlb}"/>
                </Border>

                <Grid Grid.Row="1" Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="150"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="2*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Stanga: lista masini pentru selectie -->
                    <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                           Text="Alege masina:"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource TextGri}"
                           Margin="12,12,12,6"/>
                            <TextBox DockPanel.Dock="Top"
                         x:Name="txtEditCautare"
                         FontFamily="Consolas" FontSize="12"
                         Background="#1E1E2E" Foreground="White"
                         BorderBrush="#444466" BorderThickness="1"
                         Padding="8,6" Margin="8,0,8,8"
                         TextChanged="txtEditCautare_TextChanged"/>
                            <ListBox x:Name="lstEditMasini"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#EAEAEA"
                         FontFamily="Consolas" FontSize="12"
                         Padding="8"
                         SelectionChanged="lstEditMasini_SelectionChanged"/>
                        </DockPanel>
                    </Border>

                    <!-- Dreapta: formular editare -->
                    <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20">

                                <!-- Placeholder cand nu e selectata nicio masina -->
                                <TextBlock x:Name="txtEditPlaceholder"
                               Text="Selectati o masina din lista"
                               FontFamily="Consolas" FontSize="14"
                               Foreground="{StaticResource TextGri}"
                               HorizontalAlignment="Center"
                               Margin="0,60,0,0"/>

                                <!-- Formular editare -->
                                <StackPanel x:Name="pnlEditFormular" Visibility="Collapsed">

                                    <TextBlock x:Name="txtEditTitlu"
                                   FontFamily="Consolas" FontSize="14"
                                   Foreground="{StaticResource Accent}"
                                   Margin="0,0,0,16"/>

                                    <!-- Firma -->
                                    <TextBlock Text="Firma producatoare" Style="{StaticResource StilLabel}"/>
                                    <TextBox x:Name="txtEditFirma" Style="{StaticResource StilTextBox}"
                                 Margin="0,0,0,4"/>
                                    <TextBlock x:Name="errEditFirma"
                                   Text="Firma trebuie sa aiba intre 2 si 30 de caractere!"
                                   Foreground="Red" FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,8" Visibility="Collapsed"/>

                                    <!-- Model -->
                                    <TextBlock Text="Model" Style="{StaticResource StilLabel}" Margin="0,8,0,4"/>
                                    <TextBox x:Name="txtEditModel" Style="{StaticResource StilTextBox}"
                                 Margin="0,0,0,4"/>
                                    <TextBlock x:Name="errEditModel"
                                   Text="Modelul trebuie sa aiba intre 1 si 30 de caractere!"
                                   Foreground="Red" FontFamily="Consolas" FontSize="11"
                                   Margin="0,0,0,8" Visibility="Collapsed"/>

                                    <!-- An + VIN -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="An fabricatie" Style="{StaticResource StilLabel}"/>
                                            <TextBox x:Name="txtEditAn" Style="{StaticResource StilTextBox}"
                                         Margin="0,0,0,4"/>
                                            <TextBlock x:Name="errEditAn" Foreground="Red"
                                           FontFamily="Consolas" FontSize="11"
                                           Margin="0,0,0,8" Visibility="Collapsed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Serie sasiu (VIN)" Style="{StaticResource StilLabel}"/>
                                            <TextBox x:Name="txtEditVin" Style="{StaticResource StilTextBox}"
                                         IsReadOnly="True" Opacity="0.5"
                                         Margin="0,0,0,4"/>
                                            <TextBlock Text="VIN-ul nu poate fi modificat."
                                           Foreground="#888899" FontFamily="Consolas" FontSize="11"
                                           Margin="0,0,0,8"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Data -->
                                    <TextBlock Text="Data adaugarii" Style="{StaticResource StilLabel}"
                                   Margin="0,8,0,4"/>
                                    <DatePicker x:Name="dtpEditData"
                                    Height="34" FontFamily="Consolas" FontSize="13"
                                    Background="#2A2A3E" Foreground="White"
                                    BorderBrush="#444466" SelectedDateFormat="Short"
                                    Margin="0,0,0,12"/>

                                    <!-- Culoare -->
                                    <TextBlock Text="Culoare" Style="{StaticResource StilLabel}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbEditCuloare"
                                  Style="{StaticResource StilComboBox}"
                                  Margin="0,0,0,4"
                                  SelectionChanged="cmbEditCuloare_SelectionChanged"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,12">
                                        <Border x:Name="rectEditPreview" Width="20" Height="20"
                                    CornerRadius="4" Background="#2A2A3E"
                                    BorderBrush="#444466" BorderThickness="1" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="txtEditCuloareSelectata" Text="Niciuna"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource TextGri}"
                                       VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Optiuni -->
                                    <TextBlock Text="Optiuni disponibile" Style="{StaticResource StilLabel}"
                                   Margin="0,0,0,8"/>
                                    <WrapPanel x:Name="pnlEditOptiuni" Margin="0,0,0,16"/>

                                    <!-- Butoane -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Salveaza"
                                    Style="{StaticResource StilBtn}"
                                    Height="38" FontWeight="Bold"
                                    Click="btnSalveazaEdit_Click"/>
                                        <Button Grid.Column="2" Content="Anuleaza"
                                    Style="{StaticResource StilBtnSecundar}"
                                    Height="38" Click="btnAnuleazaEdit_Click"/>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </Grid>
</Window>