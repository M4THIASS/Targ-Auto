<Window x:Class="WpfTargAuto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Targ Auto"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent"     Color="#E94560"/>
        <SolidColorBrush x:Key="CardFund"   Color="#2A2A3E"/>
        <SolidColorBrush x:Key="TextAlb"    Color="#EAEAEA"/>
        <SolidColorBrush x:Key="TextGri"    Color="#888899"/>
        <SolidColorBrush x:Key="Verde"      Color="#2ECC71"/>
        <SolidColorBrush x:Key="Galben"     Color="#F39C12"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- STANGA: lista masini -->
        <StackPanel Grid.Column="0" Background="#12122A">

            <TextBlock Text="TARG AUTO"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource Accent}"
                       FontFamily="Consolas"
                       Margin="16,20,16,4"/>

            <TextBlock Text="Masini disponibile"
                       FontSize="11"
                       Foreground="{StaticResource TextGri}"
                       FontFamily="Consolas"
                       Margin="16,0,16,16"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="480">
                <StackPanel x:Name="pnlLista" Margin="10,0,10,10"/>
            </ScrollViewer>

        </StackPanel>

        <!-- DREAPTA: detalii masina selectata -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#2A2A3E" Padding="24,18">
                <StackPanel>
                    <TextBlock x:Name="txtTitlu"
                               Text="Selectati o masina"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextAlb}"
                               FontFamily="Consolas"/>
                    <TextBlock x:Name="txtSubtitlu"
                               Text="Apasati pe o masina din lista"
                               FontSize="11"
                               Foreground="{StaticResource TextGri}"
                               FontFamily="Consolas"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Detalii -->
            <StackPanel Grid.Row="1" x:Name="pnlDetalii"
                        Visibility="Collapsed"
                        Margin="24,20,24,10">

                <!-- Firma, Model, An, VIN -->
                <Border Background="{StaticResource CardFund}"
                        CornerRadius="8" Padding="18,14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Firma"
                                   Foreground="{StaticResource TextGri}"
                                   FontFamily="Consolas" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtFirma"
                                   Foreground="{StaticResource TextAlb}"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Model"
                                   Foreground="{StaticResource TextGri}"
                                   FontFamily="Consolas" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtModel"
                                   Foreground="{StaticResource TextAlb}"
                                   FontFamily="Consolas" FontSize="13" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="An fabricatie"
                                   Foreground="{StaticResource TextGri}"
                                   FontFamily="Consolas" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtAn"
                                   Foreground="{StaticResource Galben}"
                                   FontFamily="Consolas" FontSize="13" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Serie VIN"
                                   Foreground="{StaticResource TextGri}"
                                   FontFamily="Consolas" FontSize="13"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtVin"
                                   Foreground="{StaticResource TextGri}"
                                   FontFamily="Consolas" FontSize="12"/>
                    </Grid>
                </Border>

                <!-- Culoare -->
                <Border Background="{StaticResource CardFund}"
                        CornerRadius="8" Padding="18,14" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Culoare:"
                                   Foreground="{StaticResource TextGri}"
                                   FontFamily="Consolas" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border x:Name="rectCuloare"
                                Width="28" Height="28" CornerRadius="14"
                                Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtCuloare"
                                   Foreground="{StaticResource TextAlb}"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Optiuni -->
                <Border Background="{StaticResource CardFund}"
                        CornerRadius="8" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Optiuni:"
                                   Foreground="{StaticResource TextGri}"
                                   FontFamily="Consolas" FontSize="13"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtOptiuni"
                                   Foreground="{StaticResource Verde}"
                                   FontFamily="Consolas" FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Footer -->
            <!-- Footer -->
            <Border Grid.Row="2" Background="#2A2A3E" Padding="24,12">
                <DockPanel>
                    <TextBlock x:Name="txtStatus"
                   DockPanel.Dock="Left"
                   Text="Niciun vehicul selectat"
                   Foreground="#888899"
                   FontFamily="Consolas" FontSize="11"
                   VerticalAlignment="Center"/>

                    <Button DockPanel.Dock="Right"
                Content="+ Adauga masina"
                Click="btnAdauga_Click"
                Background="#E94560"
                Foreground="White"
                BorderThickness="0"
                Padding="14,8"
                FontFamily="Consolas"
                FontSize="12"
                Cursor="Hand"
                Margin="8,0,0,0" Width="150"/>

                    <Button DockPanel.Dock="Right"
                Content="- Sterge masina"
                Click="btnSterge_Click"
                Background="#333355"
                Foreground="#AAAAAA"
                BorderThickness="0"
                Padding="14,8"
                FontFamily="Consolas"
                FontSize="12"
                Cursor="Hand" Width="150"/>
                </DockPanel>
            </Border>

        </Grid>
    </Grid>
</Window>